{
  "name": "book-rental-database",
  "version": "1.0.0",
  "description": "獨立租借書店系統 - 資料庫架構",
  "main": "index.js",
  "scripts": {
    "setup:non-relational": "node database/non-relational/migrations/init_collections.js",
    "test:connection": "node examples/test-connections.js",
    "test:supabase": "node examples/connect-supabase.js",
    "test:postgres": "node examples/connect-postgres.js",
    "test:mongodb": "node examples/connect-mongodb.js",
    "diagnose:postgres": "node examples/diagnose-postgres.js",
    "diagnose:mongodb": "node examples/diagnose-mongodb.js",
    "db:seed": "ts-node scripts/generate-seed-data.ts",
    "generate:types": "ts-node --esm scripts/generate-types-from-swagger.ts",
    "validate:types": "ts-node --esm scripts/validate-types.ts",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "database",
    "postgresql",
    "mongodb",
    "supabase",
    "schema"
  ],
  "author": "陳竑齊",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "dotenv": "^16.3.1",
    "mongodb": "^6.0.0",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.25",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}
